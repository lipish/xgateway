# LLM Link Admin Panel - Environment Configuration
# Copy this file to .env.local and adjust values as needed

# API Server URL
# This should point to your LLM Link backend server
# Default: http://localhost:8000
# 
# Examples:
# - Local development: http://localhost:8000
# - Remote server: https://api.example.com
# - Custom port: http://localhost:3000
VITE_API_URL=http://localhost:8000

